# PostgreSQL connection
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=change-me
PGDATABASE=appdb

# Backup behavior
BACKUP_OUTPUT_DIR=./backups
BACKUP_FILENAME_PREFIX=appdb-prod
BACKUP_COMPRESSION=6
PG_DUMP_PATH=pg_dump
PG_RESTORE_PATH=pg_restore

# AWS / S3
AWS_REGION=us-east-1
S3_BUCKET=my-postgres-backups
S3_PREFIX=production/appdb

# Optional static credentials. Leave empty to use IAM role / default AWS credential chain.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Optional S3 client behavior
S3_USE_PATH_STYLE=false
# S3_ENDPOINT_URL=

# Retry behavior
UPLOAD_MAX_ATTEMPTS=5
UPLOAD_INITIAL_DELAY=2s
UPLOAD_MAX_DELAY=30s

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
# For more step-by-step local output, try:
# LOG_LEVEL=debug
# LOG_FORMAT=text

# Dashboard server
HTTP_ADDR=:8080
# Set to false only for local HTTP development.
COOKIE_SECURE=true
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=30s

# Admin authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-long-random-password
JWT_SECRET=change-me-with-at-least-32-characters
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=168h
AUTH_LOGIN_RATE_LIMIT=5
AUTH_LOGIN_RATE_WINDOW=15m

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=pgbackup
MONGODB_CONNECT_TIMEOUT=10s

# Runtime defaults used when no MongoDB config document exists yet
DEFAULT_RETENTION_DAYS=30
DEFAULT_BACKUP_SCHEDULE=0 2 * * *
DEFAULT_NOTIFICATION_ENABLED=false
# DEFAULT_NOTIFICATION_WEBHOOK_URL=
DEFAULT_NOTIFICATION_WEBHOOK_TIMEOUT=10s
