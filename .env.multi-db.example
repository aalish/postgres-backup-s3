# Multi-Database Configuration Example
# Copy this to .env.multi-db and update with your actual values
# DO NOT commit .env.multi-db to version control.

# ==========================================
# MULTI-DATABASE MODE CONFIGURATION
# ==========================================

# Enable multi-database mode (REQUIRED)
MULTI_DATABASE_MODE=true

# Path to database configuration file (REQUIRED)
DATABASE_CONFIG_FILE=databases.json

# ==========================================
# DATABASE-SPECIFIC PASSWORDS
# ==========================================
# Format: PGPASSWORD_<database_id>=<password>

# Production Database Password
PGPASSWORD_production_main=change-me

# Development Database Password
PGPASSWORD_development=change-me

# ==========================================
# DEFAULT DATABASE (Fallback for dashboard)
# ==========================================
# Used when specific database is not selected

PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=change-me
PGDATABASE=postgres

# ==========================================
# MONGODB CONFIGURATION
# ==========================================

MONGO_URI=mongodb://localhost:27017/pgbackup
MONGO_DATABASE=pgbackup

# ==========================================
# AWS S3 CONFIGURATION
# ==========================================

AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=your-backup-bucket

# S3 Prefix is now handled per database in databases.json
# Example:
# Production: production/main/
# Development: development/

# ==========================================
# DASHBOARD CONFIGURATION
# ==========================================

# Dashboard HTTP settings
DASHBOARD_HTTP_ADDR=:8080
DASHBOARD_COOKIE_SECURE=false

# Dashboard authentication
DASHBOARD_AUTH_SECRET=replace-with-random-32-character-string-minimum
DASHBOARD_SESSION_DURATION=24h

# ==========================================
# BACKUP SETTINGS (Global Defaults)
# ==========================================

# These can be overridden per database in databases.json
BACKUP_COMPRESSION=6
BACKUP_TIMEOUT=3600
RETENTION_ENABLED=true

# ==========================================
# LOGGING
# ==========================================

LOG_LEVEL=info
LOG_FORMAT=text

# ==========================================
# NOTIFICATION SETTINGS (Optional)
# ==========================================

# WEBHOOK_URL=https://your-webhook-endpoint.com/notify
# WEBHOOK_SECRET=your-webhook-secret
